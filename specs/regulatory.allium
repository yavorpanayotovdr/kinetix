-- allium: 3
-- Model governance, backtesting records, stress testing governance,
-- regulatory submissions with four-eyes approval, and FRTB storage.

use "./core.allium" as core

------------------------------------------------------------
-- Entities and Variants
------------------------------------------------------------

-- Model governance

entity ModelVersion {
    model_name: String
    version: String
    status: core/ModelStatus

    transitions status {
        draft -> validated
        validated -> approved
        approved -> retired
        terminal: retired
    }

    parameters: String?
    registered_by: String
    model_tier: String?
    validation_report_url: String?
    known_limitations: String?
    approved_use_cases: String?
    next_validation_date: Date?
    approved_by: String when status = approved | retired
    approved_at: Timestamp when status = approved | retired

    @guidance
        -- model_tier classifies the model by risk impact: high | medium | low.
        -- High-tier models require more rigorous validation and shorter
        -- next_validation_date intervals.
        -- validation_report_url links to the externally stored validation document.
        -- known_limitations and approved_use_cases are free-text fields for
        -- model risk transparency — surfaced in the model governance UI.
        -- registered_by is the identity of the engineer or quant who submitted
        -- the model for registration; used to enforce the four-eyes approval check.
}

-- Backtest records

entity BacktestResultRecord {
    book_id: String
    calculation_type: String
    confidence_level: Decimal
    total_days: Integer
    violation_count: Integer
    violation_rate: Decimal
    kupiec_statistic: Decimal
    kupiec_p_value: Decimal
    kupiec_pass: Boolean
    christoffersen_statistic: Decimal
    christoffersen_p_value: Decimal
    christoffersen_pass: Boolean
    traffic_light_zone: core/TrafficLightZone
    calculated_at: Timestamp
    input_digest: String
    window_start: Date?
    window_end: Date?
    model_version: String?
}

-- Backtest comparison

value BacktestComparison {
    base: BacktestResultRecord
    target: BacktestResultRecord
    violation_count_diff: Integer
    violation_rate_diff: Decimal
    traffic_light_changed: Boolean
}

-- Stress testing governance

entity GovernedStressScenario {
    name: String
    description: String?
    shocks: String
    status: core/ScenarioStatus

    transitions status {
        draft -> pending_approval
        pending_approval -> approved
        approved -> retired
        terminal: retired
    }

    created_by: String
    approved_by: String when status = approved | retired
    approved_at: Timestamp when status = approved | retired
}

entity StressTestResultRecord {
    scenario_id: String
    book_id: String
    calculated_at: Timestamp
    base_pv: Decimal?
    stressed_pv: Decimal?
    pnl_impact: Decimal
    var_impact: Decimal?
    position_impacts: String?
    model_version: String?
}

-- Regulatory submissions

entity RegulatorySubmission {
    report_type: String
    deadline: Timestamp
    status: core/SubmissionStatus

    transitions status {
        draft -> pending_review
        pending_review -> approved
        approved -> submitted
        submitted -> acknowledged
        terminal: acknowledged
    }

    preparer_id: String
    approver_id: String when status = approved | submitted | acknowledged
    submitted_at: Timestamp when status = submitted | acknowledged
    acknowledged_at: Timestamp when status = acknowledged
}

-- FRTB calculation records

entity FrtbCalculationRecord {
    book_id: String
    total_sbm_charge: Decimal
    gross_jtd: Decimal
    hedge_benefit: Decimal
    net_drc: Decimal
    exotic_notional: Decimal
    other_notional: Decimal
    total_rrao: Decimal
    total_capital_charge: Decimal
    sbm_charges: String
    calculated_at: Timestamp
    stored_at: Timestamp
}

------------------------------------------------------------
-- Rules
------------------------------------------------------------

-- Model governance lifecycle

rule RegisterModel {
    when: RegisterModelRequested(model_name, version, parameters, registered_by)
    ensures: ModelVersion.created(
        model_name: model_name,
        version: version,
        status: draft,
        parameters: parameters,
        registered_by: registered_by
    )
}

rule ValidateModel {
    when: ValidateModelRequested(model_id)
    let model = ModelVersion{id: model_id}
    requires: model.status = draft
    ensures: model.status = validated
}

rule ApproveModel {
    when: ApproveModelRequested(model_id, approved_by)
    let model = ModelVersion{id: model_id}
    requires: model.status = validated
    requires: approved_by != model.registered_by
    ensures: model.status = approved
    ensures: model.approved_by = approved_by
    ensures: model.approved_at = now
}

rule ApproveModelRejectedSelfApproval {
    when: ApproveModelRequested(model_id, approved_by)
    let model = ModelVersion{id: model_id}
    requires: model.status = validated
    requires: approved_by = model.registered_by

    @guidance
        -- Four-eyes principle violation.
        -- Reject: the person approving a model cannot be the same person
        -- who registered it.
        -- Mirrors ApproveSubmissionRejectedSelfApproval for model governance.
}

rule RetireModel {
    when: RetireModelRequested(model_id)
    let model = ModelVersion{id: model_id}
    requires: model.status = approved
    ensures: model.status = retired
}

rule RejectInvalidModelTransition {
    when: TransitionModelRequested(model_id, target_status)
    let model = ModelVersion{id: model_id}
    requires: model.status = retired

    @guidance
        -- Retired models cannot transition further.
        -- Throws IllegalStateException.
}

-- Stress testing governance

rule CreateStressScenario {
    when: CreateStressScenarioRequested(name, description, shocks, created_by)
    ensures: GovernedStressScenario.created(
        name: name,
        description: description,
        shocks: shocks,
        status: draft,
        created_by: created_by
    )
}

rule SubmitScenarioForApproval {
    when: SubmitScenarioForApprovalRequested(scenario_id)
    let scenario = GovernedStressScenario{id: scenario_id}
    requires: scenario.status = draft
    ensures: scenario.status = pending_approval
}

rule ApproveScenario {
    when: ApproveScenarioRequested(scenario_id, approved_by)
    let scenario = GovernedStressScenario{id: scenario_id}
    requires: scenario.status = pending_approval
    ensures: scenario.status = approved
    ensures: scenario.approved_by = approved_by
    ensures: scenario.approved_at = now
}

rule RetireScenario {
    when: RetireScenarioRequested(scenario_id)
    let scenario = GovernedStressScenario{id: scenario_id}
    requires: scenario.status = approved
    ensures: scenario.status = retired
}

rule RunGovernedStressTest {
    when: RunGovernedStressTestRequested(scenario_id, book_id, model_version)
    let scenario = GovernedStressScenario{id: scenario_id}
    requires: scenario.status = approved

    @guidance
        -- Only APPROVED scenarios can be executed.
        -- pnl_impact must be computed as sum(position_market_value * price_shock)
        -- via the risk engine gRPC call — NOT by summing raw shock JSON values.
        -- The current computePnlImpact stub is a known data integrity bug:
        -- it reads shock magnitudes directly from the shocks JSON field without
        -- repricing positions, producing incorrect P&L figures.
        -- Creates StressTestResultRecord with results.
}

-- Backtest recording and comparison

rule RecordBacktest {
    when: RecordBacktestRequested(book_id, request, result)

    ensures: BacktestResultRecord.created(
        book_id: book_id,
        calculation_type: request.calculation_type,
        confidence_level: request.confidence_level,
        total_days: result.total_days,
        violation_count: result.violation_count,
        violation_rate: result.violation_rate,
        kupiec_statistic: result.kupiec_statistic,
        kupiec_p_value: result.kupiec_p_value,
        kupiec_pass: result.kupiec_pass,
        christoffersen_statistic: result.christoffersen_statistic,
        christoffersen_p_value: result.christoffersen_p_value,
        christoffersen_pass: result.christoffersen_pass,
        traffic_light_zone: result.traffic_light_zone,
        calculated_at: now,
        input_digest: digest_inputs(request),
        window_start: request.window_start,
        window_end: request.window_end,
        model_version: request.model_version
    )

    @guidance
        -- input_digest is SHA-256 of canonical request representation.
        -- Enables reproducibility verification.
}

rule CompareBacktests {
    when: CompareBacktestsRequested(base_id, target_id)
    let base = BacktestResultRecord{id: base_id}
    let target = BacktestResultRecord{id: target_id}

    @guidance
        -- Computes:
        --   violation_count_diff = target.violation_count - base.violation_count
        --   violation_rate_diff = target.violation_rate - base.violation_rate
        --   traffic_light_changed = (base.traffic_light_zone != target.traffic_light_zone)
}

-- Regulatory submissions (four-eyes principle)

rule CreateSubmission {
    when: CreateSubmissionRequested(report_type, preparer_id, deadline)
    ensures: RegulatorySubmission.created(
        report_type: report_type,
        deadline: deadline,
        status: draft,
        preparer_id: preparer_id
    )
}

rule SubmitForReview {
    when: SubmitForReviewRequested(submission_id)
    let submission = RegulatorySubmission{id: submission_id}
    requires: submission.status = draft
    ensures: submission.status = pending_review
}

rule ApproveSubmission {
    when: ApproveSubmissionRequested(submission_id, approver_id)
    let submission = RegulatorySubmission{id: submission_id}
    requires: submission.status = pending_review
    requires: approver_id != submission.preparer_id
    ensures: submission.status = approved
    ensures: submission.approver_id = approver_id
}

rule ApproveSubmissionRejectedSelfApproval {
    when: ApproveSubmissionRequested(submission_id, approver_id)
    let submission = RegulatorySubmission{id: submission_id}
    requires: submission.status = pending_review
    requires: approver_id = submission.preparer_id

    @guidance
        -- Four-eyes principle violation.
        -- Reject: approver cannot be the same person as preparer.
}

rule SubmitSubmission {
    when: SubmitSubmissionRequested(submission_id)
    let submission = RegulatorySubmission{id: submission_id}
    requires: submission.status = approved
    ensures: submission.status = submitted
    ensures: submission.submitted_at = now
}

-- FRTB calculation storage

rule StoreFrtbCalculation {
    when: StoreFrtbRequested(book_id, frtb_result)
    ensures: FrtbCalculationRecord.created(
        book_id: book_id,
        total_sbm_charge: frtb_result.sbm.total_sbm_charge,
        gross_jtd: frtb_result.drc.gross_jtd,
        hedge_benefit: frtb_result.drc.hedge_benefit,
        net_drc: frtb_result.drc.net_drc,
        exotic_notional: frtb_result.rrao.exotic_notional,
        other_notional: frtb_result.rrao.other_notional,
        total_rrao: frtb_result.rrao.total_rrao,
        total_capital_charge: frtb_result.total_capital_charge,
        sbm_charges: frtb_result.sbm.risk_class_charges,
        calculated_at: frtb_result.calculated_at,
        stored_at: now
    )
}

------------------------------------------------------------
-- Config
------------------------------------------------------------

config {
    backtest_result_retention: Duration = 7.years
    stress_test_result_retention: Duration = 7.years
}

-- Note: backtest_result_retention was previously 3 years, which is insufficient
-- under current compliance requirements. Both backtest and stress test results
-- must be retained for the full 7-year regulatory audit period.

------------------------------------------------------------
-- Invariants
------------------------------------------------------------

invariant ModelStatusTransitions {
    @guidance
        -- Valid transitions:
        --   draft -> validated
        --   validated -> approved
        --   approved -> retired
        -- No other transitions permitted.
        -- Retired is a terminal state.
}

invariant ScenarioStatusTransitions {
    @guidance
        -- Valid transitions:
        --   draft -> pending_approval
        --   pending_approval -> approved
        --   approved -> retired
        -- Only approved scenarios can be executed.
}

invariant SubmissionFourEyes {
    for s in RegulatorySubmissions:
        s.approver_id = null or s.approver_id != s.preparer_id
}

invariant SubmissionStatusTransitions {
    @guidance
        -- Valid transitions:
        --   draft -> pending_review
        --   pending_review -> approved
        --   approved -> submitted
        --   submitted -> acknowledged (external)
}

invariant BacktestInputReproducibility {
    @guidance
        -- Two backtest runs with the same input_digest (SHA-256)
        -- must produce identical statistical results.
}

invariant ModelApprovalFourEyes {
    for m in ModelVersions:
        m.approved_by = null or m.approved_by != m.registered_by

    @guidance
        -- The person approving a model must differ from the person who registered it.
        -- Enforces separation of duties in the model governance lifecycle.
        -- Mirrors SubmissionFourEyes for model approvals.
}

invariant StressTestResultRetention {
    @guidance
        -- Stress test results (StressTestResultRecord) must be retained for
        -- config.stress_test_result_retention (7 years) for regulatory audit purposes.
        -- Results must not be deleted or archived to inaccessible storage within
        -- this window. The retention policy must be enforced at the database level
        -- (TimescaleDB retention policy or equivalent) and verified in compliance audits.
}
