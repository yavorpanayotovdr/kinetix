{
  "uid": "kinetix-risk-overview",
  "title": "Risk Overview",
  "tags": [
    "kinetix",
    "risk"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "links": [
    { "title": "System Health", "type": "link", "url": "/d/kinetix-system-health", "icon": "dashboard" },
    { "title": "Service Overview", "type": "link", "url": "/d/kinetix-service-overview", "icon": "dashboard" },
    { "title": "Trade Flow", "type": "link", "url": "/d/kinetix-trade-flow", "icon": "dashboard" },
    { "title": "Risk Engine", "type": "link", "url": "/d/kinetix-risk-engine?var-book_id=${book_id}", "icon": "dashboard" },
    { "title": "Risk Orchestrator", "type": "link", "url": "/d/kinetix-risk-orchestrator?var-book_id=${book_id}", "icon": "dashboard" },
    { "title": "Price", "type": "link", "url": "/d/kinetix-prices", "icon": "dashboard" },
    { "title": "Kafka Health", "type": "link", "url": "/d/kinetix-kafka-health", "icon": "dashboard" },
    { "title": "Database Health", "type": "link", "url": "/d/kinetix-database-health", "icon": "dashboard" },
    { "title": "Service Logs", "type": "link", "url": "/d/kinetix-service-logs", "icon": "dashboard" }
  ],
  "templating": {
    "list": [
      {
        "name": "book_id",
        "type": "query",
        "label": "Book",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(risk_var_value, book_id)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".+",
        "current": { "text": "All", "value": "$__all" },
        "multi": true,
        "sort": 1
      },
      {
        "name": "calculation_type",
        "type": "query",
        "label": "Method",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(risk_var_value, calculation_type)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "sort": 1
      },
      {
        "name": "confidence_level",
        "type": "query",
        "label": "Confidence",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(risk_var_value, confidence_level)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Current VaR",
      "type": "gauge",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "risk_var_value{book_id=~\"$book_id\", calculation_type=\"$calculation_type\", confidence_level=\"$confidence_level\"}",
          "legendFormat": "{{book_id}} ({{calculation_type}} @ {{confidence_level}})",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 500000
              },
              {
                "color": "red",
                "value": 1000000
              }
            ]
          },
          "unit": "currencyUSD"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "id": 2,
      "title": "VaR Trend",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "expr": "risk_var_value{book_id=~\"$book_id\", calculation_type=\"$calculation_type\", confidence_level=\"$confidence_level\"}",
          "legendFormat": "{{book_id}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "id": 3,
      "title": "Expected Shortfall (CVaR)",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "expr": "risk_var_expected_shortfall{book_id=~\"$book_id\", calculation_type=\"$calculation_type\", confidence_level=\"$confidence_level\"}",
          "legendFormat": "{{book_id}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "id": 4,
      "title": "VaR Component Breakdown",
      "type": "barchart",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "risk_var_component_contribution{book_id=~\"$book_id\"}",
          "legendFormat": "{{book_id}} / {{asset_class}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    },
    {
      "id": 5,
      "title": "VaR Calculation Count",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(rate(risk_var_calculation_total[5m]))",
          "legendFormat": "Calculations/s",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
